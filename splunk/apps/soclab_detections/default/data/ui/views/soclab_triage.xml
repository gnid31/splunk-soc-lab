<dashboard version="1.1" theme="dark">
  <label>SOC Lab — Analyst Triage</label>
  <description>Real-time view of correlated detections, mapped to MITRE ATT&amp;CK.</description>

  <row>
    <panel>
      <title>Notable Events — Last 24h</title>
      <single>
        <search>
          <query>index=notable NOT eventtype=notable_suppression | stats count</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0x53a051","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[10,50]</option>
      </single>
    </panel>
    <panel>
      <title>Critical Severity — Last 24h</title>
      <single>
        <search>
          <query>index=notable severity=critical | stats count</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0x53a051","0xdc4e41"]</option>
        <option name="rangeValues">[1]</option>
      </single>
    </panel>
    <panel>
      <title>Distinct Hosts w/ Detections</title>
      <single>
        <search>
          <query>index=notable | stats dc(host) as hosts</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Detections by MITRE Technique (24h)</title>
      <chart>
        <search>
          <query>index=notable | stats count by mitre_technique | sort -count</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">bar</option>
      </chart>
    </panel>
    <panel>
      <title>Detections by MITRE Tactic (24h)</title>
      <chart>
        <search>
          <query>index=notable | stats count by mitre_tactic | sort -count</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">pie</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Detection Timeline</title>
      <chart>
        <search>
          <query>index=notable | timechart span=15m count by severity</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Recent Notable Events</title>
      <table>
        <search>
          <query>index=notable | table _time, host, mitre_technique, mitre_tactic, severity, rule_title, rule_description | sort -_time | head 50</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top Hosts by Detection Count</title>
      <table>
        <search>
          <query>index=notable | stats count, values(mitre_technique) as techniques by host | sort -count</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
      </table>
    </panel>
    <panel>
      <title>Top Failed Logon Sources (Brute Force Candidates)</title>
      <table>
        <search>
          <query>(index=wineventlog EventCode=4625) OR (index=linux_auditd "Failed password") | eval src_ip=coalesce(src_ip, IpAddress) | stats count as failures by src_ip, host | sort -failures | head 20</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
      </table>
    </panel>
  </row>
</dashboard>
