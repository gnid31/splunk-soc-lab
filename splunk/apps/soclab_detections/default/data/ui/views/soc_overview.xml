<dashboard version="1.1" theme="dark" hideEdit="false">
  <label>1. SOC Overview</label>
  <description>Executive view — key KPIs at a glance. First dashboard an analyst opens.</description>

  <search id="baseNotable">
    <query>index=notable</query>
    <earliest>$time.earliest$</earliest>
    <latest>$time.latest$</latest>
  </search>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Total Notable Events</title>
      <single>
        <search base="baseNotable">
          <query>| stats count</query>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[10,50,100]</option>
        <option name="useColors">1</option>
        <option name="drilldown">all</option>
      </single>
      <drilldown>
        <link target="_blank">/app/soclab_detections/soclab_triage?form.time.earliest=$time.earliest$&amp;form.time.latest=$time.latest$</link>
      </drilldown>
    </panel>

    <panel>
      <title>Critical Detections</title>
      <single>
        <search>
          <query>index=sysmon EventCode=10 TargetImage="*\\lsass.exe" GrantedAccess IN ("0x1010","0x1410","0x1438","0x143a","0x1fffff") NOT SourceImage IN ("*\\svchost.exe","*\\wininit.exe","*\\services.exe","*\\csrss.exe","*\\MsMpEng.exe") | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0xdc4e41"]</option>
        <option name="rangeValues">[1]</option>
        <option name="useColors">1</option>
      </single>
    </panel>

    <panel>
      <title>Affected Hosts</title>
      <single>
        <search base="baseNotable">
          <query>| stats dc(host) as hosts</query>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[1,3]</option>
        <option name="useColors">1</option>
      </single>
    </panel>

    <panel>
      <title>MITRE Techniques Triggered</title>
      <single>
        <search base="baseNotable">
          <query>| stats dc(mitre_technique) as techniques</query>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xdc4e41"]</option>
        <option name="rangeValues">[3,7]</option>
        <option name="useColors">1</option>
      </single>
    </panel>

    <panel>
      <title>Detection Rate (per hour)</title>
      <single>
        <search base="baseNotable">
          <query>| bin _time span=1h | stats count as c by _time | stats avg(c) as avg_per_hour | eval avg_per_hour=round(avg_per_hour,1)</query>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[5,20]</option>
        <option name="unit">/hr</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Notable Events Timeline (by MITRE Tactic)</title>
      <chart>
        <search base="baseNotable">
          <query>| timechart span=5m count by mitre_tactic</query>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="height">280</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top MITRE Techniques</title>
      <chart>
        <search base="baseNotable">
          <query>| stats count by mitre_technique | sort -count | head 10</query>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.legend.placement">none</option>
      </chart>
    </panel>

    <panel>
      <title>Detections by MITRE Tactic</title>
      <chart>
        <search base="baseNotable">
          <query>| stats count by mitre_tactic</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.showDataLabels">all</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Data Ingestion — Events per Source (last hour)</title>
      <chart>
        <search>
          <query>| tstats count where index IN (wineventlog, sysmon, linux_auditd, suricata, zeek) by index _time span=5m | timechart span=5m sum(count) by index</query>
          <earliest>-1h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
  </row>
</dashboard>
